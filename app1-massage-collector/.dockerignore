# ─────────────────────────────────────────────────────────────────────────────
# .dockerignore — App 1
# ─────────────────────────────────────────────────────────────────────────────
# This file tells Docker which files to EXCLUDE from the build context.
# Similar to .gitignore but for Docker.
# Excluding unnecessary files: speeds up build, shrinks image size.
# ─────────────────────────────────────────────────────────────────────────────

# Python cache and bytecode — generated at runtime, never needed in image
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environment — we use pip inside the container, not a venv
venv/
env/
.venv/
.env/

# Git history — not needed inside the container
.git/
.gitignore

# Development tools
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# This file itself
.dockerignore
